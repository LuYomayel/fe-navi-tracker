{
  "name": "habit-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "NODE_OPTIONS='--max-old-space-size=2048' next build",
    "build:fast": "NODE_OPTIONS='--max-old-space-size=1024' SKIP_TYPE_CHECK=true next build",
    "build:vps": "NODE_OPTIONS='--max-old-space-size=2048' next build",
    "build:mobile": "NEXT_PUBLIC_BUILD_TARGET=capacitor NEXT_PUBLIC_API_URL=https://api-navi-tracker.luciano-yomayel.com NEXT_PUBLIC_BACKEND_URL=https://api-navi-tracker.luciano-yomayel.com NODE_OPTIONS='--max-old-space-size=2048' next build",
    "cap:sync": "npm run build:mobile && cap sync",
    "cap:android": "npm run cap:sync && cap open android",
    "cap:ios": "npm run cap:sync && cap open ios",
    "cap:run:android": "npm run cap:sync && cap run android",
    "cap:run:ios": "npm run cap:sync && cap run ios",
    "postbuild": "node scripts/copy-public.js",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit --skipLibCheck",
    "test": "npm run lint && npm run type-check && npm run build:fast",
    "deploy": "./scripts/deploy.sh",
    "deploy:prod": "./scripts/deploy.sh --production",
    "clean": "rm -rf .next out node_modules",
    "reinstall": "npm run clean && npm install",
    "audit:fix": "npm audit fix",
    "check:deps": "npm outdated",
    "update:deps": "npm update"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.6",
    "@capacitor/app": "^7.1.2",
    "@capacitor/browser": "^7.0.5",
    "@capacitor/camera": "^7.0.5",
    "@capacitor/cli": "^7.6.6",
    "@capacitor/core": "^7.6.6",
    "@capacitor/device": "^7.0.5",
    "@capacitor/haptics": "^7.0.5",
    "@capacitor/ios": "^7.6.6",
    "@capacitor/keyboard": "^7.0.6",
    "@capacitor/local-notifications": "^7.0.6",
    "@capacitor/preferences": "^7.0.4",
    "@capacitor/push-notifications": "^7.0.6",
    "@capacitor/splash-screen": "^7.0.5",
    "@capacitor/status-bar": "^7.0.6",
    "@capawesome/capacitor-file-picker": "^7.2.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-tooltip": "^1.2.7",
    "autoprefixer": "^10.4.17",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.523.0",
    "next": "^15.5.12",
    "next-auth": "^4.24.11",
    "next-pwa": "^5.6.0",
    "openai": "^5.7.0",
    "pdfjs-dist": "^5.5.207",
    "postcss": "^8.4.35",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.0.0",
    "sharp": "^0.34.2",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/next-pwa": "^5.6.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.3.4",
    "typescript": "5.9.3",
    "workbox-webpack-plugin": "^7.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
